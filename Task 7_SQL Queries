fetching details of table Movie:

 select * from movie;

Review Table creation:

create table Review(
Moviename VARCHAR(50),
foreign key (Moviename) references Movie(Moviename),
Review int);


Inserting values into the table:

insert into Review values ('Gilly','7'),
('Mahanadi','9'),
('Aranmani','8.5');

fetching details of table Review

select * from Review;

Fetching details from both Movie and Review tables which are all have the same movie name using INNER JOIN:

select * from Movie
inner join Review
on Movie.Moviename = Review.Moviename;

Artist Table creation:

create table Artist(
Artistname varchar(50) Primary Key,
Skills varchar(50));



Roles Table creation:

create table Roles(
Artistname varchar(50),
Moviename VARCHAR(50),
foreign key (Artistname) references Artist(Artistname),
foreign key (Moviename) references Movie(Moviename),
Roles varchar(50));


Inserting values into the table:

insert into Roles values('Siddhu','Aranmani','Hero'),
('Gemini','Mahanadi','Hero'),
('Siva','Kalakalapu','Hero and Comedian');

fetching details of table Roles

select * from Roles;

Fetching details from both Movie and Review tables using RightJOIN:

select artist.Artistname, artist.skills, roles.roles
from Artist
right join Roles
on artist.Artistname = Roles.Artistname;




Fetching details from all the tables of a artist using multiple JOIN:

select movie.Moviename, movie.artistname,Review.Review,artist.skills, Roles.roles
from movie join Review on Movie.moviename=review.Moviename
join artist on movie.Artistname = artist.Artistname
join roles on artist.Artistname = roles.Artistname;







